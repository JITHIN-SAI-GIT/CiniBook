# Database Configuration (Local MySQL — used with `local` profile)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cinebook
DB_USER=root
DB_PASSWORD=YOUR_DATABASE_PASSWORD



# External APIs
TMDB_API_KEY=YOUR_TMDB_API_KEY
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

# SMTP Mail Server
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_GMAIL_USERNAME
MAIL_PASSWORD=YOUR_SMTP_APP_PASSWORD

# Backblaze B2 Video Storage
B2_KEY_ID=YOUR_B2_KEY_ID
B2_APPLICATION_KEY=YOUR_B2_APPLICATION_KEY
B2_BUCKET_NAME=YOUR_B2_BUCKET_NAME
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com

# Google Drive Video Storage
GOOGLE_DRIVE_CLIENT_ID=YOUR_GOOGLE_DRIVE_CLIENT_ID
GOOGLE_DRIVE_CLIENT_SECRET=YOUR_GOOGLE_DRIVE_CLIENT_SECRET
GOOGLE_DRIVE_REFRESH_TOKEN=YOUR_GOOGLE_DRIVE_REFRESH_TOKEN
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID
